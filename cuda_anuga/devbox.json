{
  "packages": [
    "python312@latest",
    "cudaPackages.cudatoolkit@latest",
    "gcc12@latest",
    "gnumake@latest",
    "pkg-config@latest",
    "openmpi@latest",
    "gdal@latest",
    "netcdf@latest",
    "hdf5@latest"
  ],
  "env": {
    "CUDA_HOME": "{{ .Virtenv }}/cuda",
    "LD_LIBRARY_PATH": "$CUDA_HOME/lib64:$LD_LIBRARY_PATH",
    "PATH": "$CUDA_HOME/bin:$PATH"
  },
  "shell": {
    "init_hook": [
      "echo '================================================'",
      "echo ' ANUGA CUDA Development Environment'",
      "echo '================================================'",
      "echo ''",
      "echo 'Python:' $(python3 --version)",
      "echo 'nvcc:' $(nvcc --version 2>/dev/null | tail -1 || echo 'not found')",
      "echo 'gcc:' $(gcc --version | head -1)",
      "echo ''",
      "echo 'Run ./setup.sh to install Python dependencies.'",
      "echo ''"
    ],
    "scripts": {
      "setup": ["bash setup.sh"],
      "test":  ["python3 test_cuda_cross_domain.py"],
      "profile": ["nsys profile --stats=true python3 test_cuda_cross_domain.py"]
    }
  }
}
